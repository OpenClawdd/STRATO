# STRATO — Environment Variables
# Copy this file to .env and change the values.

# Password required to access the dashboard (TOS gateway)
SITE_PASSWORD=changeme

# Secret used to sign session cookies — use a long random string
COOKIE_SECRET=change_this_to_a_long_random_string

# Port the server listens on
PORT=8080

# Set to "true" if serving over HTTPS (enables Secure flag on cookies)
SECURE_COOKIES=false

# Indicates the environment (e.g. production, development). Required for cookie security flag to be active.
NODE_ENV=development
