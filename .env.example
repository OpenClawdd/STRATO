# ════════════════════════════════════════════════════════════════
# STRATO v21 — Environment Configuration
# ════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# DO NOT commit .env to Git — it is in .gitignore
#
# Variables marked [REQUIRED] must be set in production.
# Variables marked [OPTIONAL] have sensible defaults.
# Proxy/hub variables are resolved at runtime via ${VAR} placeholders
# in games.json and proxy-mirrors.json. Leave them empty to show
# "Configure in .env" overlays in the UI.
# ════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────
#  SERVER CONFIGURATION
# ──────────────────────────────────────────────────

# [REQUIRED] Port the HTTP server listens on.
# Default: 8080
PORT=8080

# [REQUIRED] Node environment — controls cookie security, HSTS, etc.
# Use "production" for deployed instances, "development" for local work.
NODE_ENV=production

# [REQUIRED] Secret key for signing cookies (auth sessions, CSRF tokens).
# MUST be a strong random string in production. Generate with:
#   openssl rand -hex 32
# WARNING: The server will refuse to start in production without this.
COOKIE_SECRET=


# ──────────────────────────────────────────────────
#  PROXY MIRRORS — Good Proxies (Tier 1)
# ──────────────────────────────────────────────────
# These are the highest-reliability proxy sites.
# Set the full URL including protocol (https://).

PROXY_SPLASH=
PROXY_STRAWBERRY=

# ── Recommended Proxies (Tier 2) ──
# These have moderate reliability. Some require passwords or have
# alternate domains for when the primary is blocked.

PROXY_SELENITE=
PROXY_SELENITE_ALT=
PROXY_FMHY=
PROXY_VAPOR=
PROXY_AWP=
PROXY_AWP_ALT=
PROXY_FROGIES=
PROXY_SME=
PROXY_SME_ALT=
PROXY_SME_PASSWORD=
PROXY_CHERRI=
PROXY_CHERRI_ALT=
PROXY_LUCIDE=
PROXY_INFAMOUS=
PROXY_NOAHS=

# ── PeteZah (has alt CDN) ──
PROXY_PETEZAH=
PROXY_PETEZAH_ALT=


# ──────────────────────────────────────────────────
#  GAME HUBS (Tier 3)
# ──────────────────────────────────────────────────
# External game hub sites that host unblocked games.
# Set the full URL including protocol.

HUB_UUNNBLOCKED=
HUB_IMP=
HUB_DAYDREAM=
HUB_GHOST=
HUB_GHOST_ALT=
HUB_NEXORA=
HUB_QUASAR=
HUB_KEOFFICAL=
HUB_BOREDOM=
HUB_ENDIS=
HUB_EVEREST=
HUB_KORONA=
HUB_UBGHUB=
HUB_PIZAGAME=
HUB_RONIN=
HUB_LEARNING=
HUB_MIST=
HUB_SAKURA=
HUB_INFINITY=
HUB_REDS=


# ──────────────────────────────────────────────────
#  STEALTH / TAB CLOAK FAVICONS
# ──────────────────────────────────────────────────
# Community cloak presets use ${CLOAK_*_FAVICON} placeholders.
# Set these to the favicon URLs of the sites you want to impersonate.
# If left empty, the cloak will fall back to /favicon.ico.

CLOAK_SCHOOL_AGRECA_FAVICON=
CLOAK_NOAHS_FAVICON=
CLOAK_BYOD_FAVICON=
CLOAK_ECLIPSE_FAVICON=
CLOAK_LEARNING_FAVICON=
CLOAK_PETEZAH_FAVICON=
CLOAK_SME_FAVICON=
CLOAK_CHERRI_FAVICON=


# ──────────────────────────────────────────────────
#  AI CONFIGURATION [OPTIONAL]
# ──────────────────────────────────────────────────
# STRATO uses z-ai-web-dev-sdk for AI Tutor, Snap & Solve, and
# general AI chat. These features require a .z-ai-config file
# in the project root (auto-detected at startup).
#
# If .z-ai-config is not present, AI features gracefully disable.
# No environment variables are needed — the SDK reads its own config.
#
# To enable AI features:
#   1. Create .z-ai-config in the project root with your API credentials
#   2. Restart the server
#   3. Check /api/ai/status to verify AI is online


# ──────────────────────────────────────────────────
#  ADMIN CONFIGURATION [OPTIONAL]
# ──────────────────────────────────────────────────
# These variables are reserved for future admin panel features.
# Currently unused in v21 but provided for forward compatibility.

# Admin username for the management panel (future feature)
# ADMIN_USERNAME=

# Admin password — use a strong bcrypt hash
# ADMIN_PASSWORD_HASH=

# Comma-separated list of admin email addresses for alerts
# ADMIN_EMAIL=


# ──────────────────────────────────────────────────
#  ADVANCED / TUNING [OPTIONAL]
# ──────────────────────────────────────────────────
# These have sensible defaults. Only change if you know what you're doing.

# Maximum request body size (default: 10mb)
# BODY_LIMIT=10mb

# Rate limit: max API requests per minute per IP (default: 60)
# RATE_LIMIT_API=60

# Rate limit: max chat messages per minute per IP (default: 30)
# RATE_LIMIT_CHAT=30

# Rate limit: max save operations per minute per IP (default: 10)
# RATE_LIMIT_SAVES=10

# Login rate limit: max attempts before 60s lockout (default: 8)
# LOGIN_MAX_ATTEMPTS=8

# CSRF token time-to-live in milliseconds (default: 600000 = 10 min)
# CSRF_TTL=600000

# Auth cookie max age in milliseconds (default: 604800000 = 7 days)
# COOKIE_MAX_AGE=604800000

# Trust first proxy — set to 1 when behind a reverse proxy (default: 1)
# TRUST_PROXY=1
