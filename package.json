	},
	"dependencies": {
		"@mercuryworkshop/wisp-js": "^0.4.1",
		"compression": "^1.8.1",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.2.1",
		"express": "^5.2.1",
		"express-rate-limit": "^7.5.1",
		"helmet": "^8.1.0",
		"ws": "^8.19.0"
