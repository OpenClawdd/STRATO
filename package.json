{
  "name": "strato",
  "version": "5.0.3",
  "description": "STRATO v5.02 — Catalog Purge + Surface Split: playable games stay clean, non-playable surfaces live outside Home/Search/Picks.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ public/js/v5/ scripts/validate-games.mjs scripts/validate-sources.mjs scripts/import-raw-sources.mjs",
    "format": "prettier --write 'src/**/*.js' 'public/js/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'public/js/**/*.js'",
    "postinstall": "node scripts/setup-proxy.cjs",
    "source:check": "node scripts/check-sources.mjs",
    "source:check:json": "node scripts/check-sources.mjs --json",
    "source:report": "node scripts/catalog-report.mjs",
    "source:validate": "node scripts/validate-sources.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@mercuryworkshop/bare-mux": "^2.1.8",
    "@mercuryworkshop/epoxy-tls": "^2.1.19-1",
    "@mercuryworkshop/epoxy-transport": "^3.0.1",
    "@mercuryworkshop/scramjet": "^1.0.2",
    "@mercuryworkshop/wisp-js": "^0.4.1",
    "@titaniumnetwork-dev/ultraviolet": "^3.2.10",
    "@tomphttp/bare-server-node": "^2.0.6",
    "canvas": "^3.2.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.2",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "uuid": "^11.1.1",
    "ws": "^8.19.0",
    "z-ai-web-dev-sdk": "^0.0.17"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "ultraviolet",
    "scramjet",
    "games",
    "arcade",
    "self-hosted"
  ],
  "license": "GPL-3.0"
}
