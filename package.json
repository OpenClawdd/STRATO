	"description": "STRATO — A fast, secure proxy and arcade dashboard.",
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"start": "node src/index.js",
		"dev": "node --watch src/index.js",
