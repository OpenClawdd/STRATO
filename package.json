{
  "name": "strato",
  "version": "13.0.0",
  "description": "STRATO v13 — Web proxy and game hub for school Chromebooks. NEXUS.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.js' 'public/js/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'public/js/**/*.js'",
    "postinstall": "node scripts/setup-proxy.cjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@mercuryworkshop/bare-mux": "^2.1.8",
    "@mercuryworkshop/epoxy-tls": "^2.1.19-1",
    "@mercuryworkshop/scramjet": "^1.0.2",
    "@mercuryworkshop/wisp-js": "^0.4.1",
    "@titaniumnetwork-dev/ultraviolet": "^3.2.10",
    "@tomphttp/bare-server-node": "^2.0.6",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ws": "^8.19.0",
    "z-ai-web-dev-sdk": "^0.0.17"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "prettier": "^3.4.2"
  },
  "keywords": ["proxy", "ultraviolet", "scramjet", "games", "school", "chromebook"],
  "license": "GPL-3.0"
}
